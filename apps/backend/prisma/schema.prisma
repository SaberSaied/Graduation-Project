generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  password      String
  emailVerified Boolean        @default(false)
  image         String?
  currency      String         @default("USD")
  financialGoal String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  budgets       Budget[]
  categories    Category[]
  chatSessions  ChatSession[]
  goals         Goal[]
  notifications Notification[]
  transactions  Transaction[]
  obligations   FinancialObligation[]
  reminders     BillReminder[]

  @@map("users")
}

model Category {
  id           String        @id @default(cuid())
  name         String
  icon         String
  color        String
  type         CategoryType
  isDefault    Boolean       @default(false)
  userId       String?
  createdAt    DateTime      @default(now())
  budgets      Budget[]
  transactions Transaction[]
  obligations  FinancialObligation[]
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("categories")
}

model Transaction {
  id                   String          @id @default(cuid())
  userId               String
  categoryId           String
  type                 TransactionType
  amount               Float
  currency             String
  amountInBaseCurrency Float
  exchangeRate         Float           @default(1.0)
  title                String
  notes                String?
  date                 DateTime
  isRecurring          Boolean         @default(false)
  recurringInterval    RecurringType?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  category             Category        @relation(fields: [categoryId], references: [id])
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  goalContribution GoalContribution?
  obligationPayment ObligationPayment?

  @@index([userId, date])
  @@index([userId, type])
  @@map("transactions")
}

model Budget {
  id             String       @id @default(cuid())
  userId         String
  categoryId     String
  amount         Float
  currency       String
  period         BudgetPeriod @default(MONTHLY)
  startDate      DateTime?
  endDate        DateTime?
  alertThreshold Float        @default(0.8)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  category       Category     @relation(fields: [categoryId], references: [id])
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, period, startDate, endDate])
  @@map("budgets")
}

model Goal {
  id                 String             @id @default(cuid())
  userId             String
  title              String
  description        String?
  targetAmount       Float
  savedAmount        Float              @default(0)
  currency           String
  deadline           DateTime?
  icon               String?
  color              String?
  status             GoalStatus         @default(IN_PROGRESS)
  autoSaveAmount     Float?
  autoSavePercentage Float?
  autoSaveFrequency  AutoSaveFrequency?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  contributions      GoalContribution[]
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model GoalContribution {
  id            String       @id @default(cuid())
  goalId        String
  transactionId String?      @unique
  amount        Float
  note          String?
  date          DateTime     @default(now())
  goal          Goal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  @@map("goal_contributions")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_sessions")
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  role          MessageRole
  content       String
  createdAt     DateTime    @default(now())
  session       ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  CUSTOM
}

enum AutoSaveFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum RecurringType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum GoalStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationType {
  BUDGET_ALERT
  GOAL_PROGRESS
  AI_INSIGHT
  OVERSPEND_WARNING
  MONTHLY_SUMMARY
}

enum MessageRole {
  USER
  ASSISTANT
}

model FinancialObligation {
  id              String           @id @default(cuid())
  userId          String
  categoryId      String?
  title           String
  description     String?
  amount          Float
  currency        String
  type            ObligationType
  status          ObligationStatus @default(UPCOMING)
  dueDate         DateTime?
  isRecurring     Boolean          @default(false)
  recurringType   RecurringType?
  startDate       DateTime         @default(now())
  endDate         DateTime?
  
  // Subscription specific
  autoRenew       Boolean?         @default(true)
  
  // Debt/Loan specific
  totalAmount     Float?           
  remainingAmount Float?           
  interestRate    Float?           
  lenderInfo      String?
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category?        @relation(fields: [categoryId], references: [id])
  reminders       BillReminder[]
  payments        ObligationPayment[]

  @@map("financial_obligations")
}

model BillReminder {
  id              String           @id @default(cuid())
  obligationId    String
  userId          String
  reminderDate    DateTime
  isSent          Boolean          @default(false)
  type            ReminderType     @default(IN_APP)
  
  obligation      FinancialObligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bill_reminders")
}

model ObligationPayment {
  id              String           @id @default(cuid())
  obligationId    String
  transactionId   String?          @unique
  amount          Float
  paymentDate     DateTime         @default(now())
  status          PaymentStatus    @default(COMPLETED)
  
  obligation      FinancialObligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)
  transaction     Transaction?        @relation(fields: [transactionId], references: [id])

  @@map("obligation_payments")
}

enum ObligationStatus {
  PAID
  UPCOMING
  OVERDUE
  PAUSED
}

enum ObligationType {
  SUBSCRIPTION
  BILL
  DEBT
  LOAN
  INSTALLMENT
}

enum ReminderType {
  PUSH
  IN_APP
  DASHBOARD
}

enum PaymentStatus {
  COMPLETED
  PENDING
  FAILED
}
